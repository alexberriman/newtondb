{
  "name": "newtondb",
  "version": "2.0.0-beta.0",
  "description": "A correctness-first, TypeScript-native JSON document database.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "node scripts/clean.mjs",
    "coverage": "vitest run --coverage",
    "docs": "typedoc",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "lint": "eslint .",
    "pack:check": "npm run build && publint && attw --pack . --profile esm-only",
    "release:check": "node scripts/check-release.mjs",
    "test": "vitest run",
    "test:crash": "npm run build && node scripts/crash-harness.mjs && node scripts/process-lock-harness.mjs",
    "test:package": "npm run build && node scripts/package-smoke.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:crash && npm run coverage && npm run pack:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexberriman/newtondb.git"
  },
  "keywords": [
    "json",
    "database",
    "typescript",
    "document-database",
    "embedded-database"
  ],
  "author": "Alex Berriman <alexb@bezz.com.au>",
  "license": "MIT",
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/alexberriman/newtondb/issues"
  },
  "homepage": "https://github.com/alexberriman/newtondb#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.20.0",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.0",
    "publint": "^0.3.21",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
